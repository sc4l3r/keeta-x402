{
  "name": "keeta-x402",
  "version": "0.1.0",
  "description": "Example of how to use x402 with Keeta",
  "type": "module",
  "scripts": {
    "facilitator": "pnpm --filter facilitator start",
    "resource-server": "pnpm --filter server start",
    "client": "pnpm --filter client start",
    "build": "pnpm --filter facilitator build && pnpm --filter server build",
    "typecheck": "pnpm -r exec tsc --noEmit"
  },
  "keywords": [],
  "author": "sc4l3r",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sc4l3r/keeta-x402"
  },
  "packageManager": "pnpm@10.5.0",
  "pnpm": {
    "overrides": {
      "@x402/keeta": "workspace:*",
      "@x402/core": "workspace:*"
    }
  }
}
